---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  hero?: boolean;
  bandTitle?: string;
  bandSubtitle?: string;
}

const {
  title,
  description = "Diogo Silva — full-stack developer, ML systems.",
  hero = false,
  bandTitle,
  bandSubtitle,
} = Astro.props;

const navy = hero || Boolean(bandTitle);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content={new URL("/energia-dashboard.png", Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body class={navy ? "has-hero" : ""}>
    {
      navy ? (
        <div class={`hero-wrap${bandTitle ? " compact" : ""}`}>
          <header class="site-header">
            <a href="/" class="brand">Diogo Silva</a>
            <nav>
              <a href="/">Home</a>
              <a href="/posts/">Writing</a>
              <a href="/cv/">CV</a>
            </nav>
          </header>
          {hero ? (
            <div class="hero">
              <slot name="hero" />
            </div>
          ) : (
            <div class="page-band">
              <h1>{bandTitle}</h1>
              {bandSubtitle && <p>{bandSubtitle}</p>}
            </div>
          )}
        </div>
      ) : (
        <header class="site-header">
          <a href="/" class="brand">Diogo Silva</a>
          <nav>
            <a href="/">Home</a>
            <a href="/posts/">Writing</a>
            <a href="/cv/">CV</a>
          </nav>
        </header>
      )
    }
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      Diogo Guimarães Silva ·
      <a href="https://github.com/diogogs">GitHub</a> ·
      <a href="https://www.linkedin.com/in/diogo-guimaraes-silva">LinkedIn</a> ·
      <a href="mailto:dgsilvacr2017@gmail.com">dgsilvacr2017@gmail.com</a>
    </footer>
  </body>
</html>
