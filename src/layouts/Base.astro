---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  hero?: boolean;
}

const {
  title,
  description = "Diogo Silva — full-stack developer, ML systems.",
  hero = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class={hero ? "has-hero" : ""}>
    {
      hero ? (
        <div class="hero-wrap">
          <header class="site-header">
            <a href="/" class="brand">Diogo Silva</a>
            <nav>
              <a href="/">Home</a>
              <a href="/posts/">Writing</a>
              <a href="/cv/">CV</a>
            </nav>
          </header>
          <div class="hero">
            <slot name="hero" />
          </div>
        </div>
      ) : (
        <header class="site-header">
          <a href="/" class="brand">Diogo Silva</a>
          <nav>
            <a href="/">Home</a>
            <a href="/posts/">Writing</a>
            <a href="/cv/">CV</a>
          </nav>
        </header>
      )
    }
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      Diogo Guimarães Silva ·
      <a href="https://github.com/diogogs">GitHub</a> ·
      <a href="https://www.linkedin.com/in/diogo-guimaraes-silva">LinkedIn</a> ·
      <a href="mailto:dgsilvacr2017@gmail.com">dgsilvacr2017@gmail.com</a>
    </footer>
  </body>
</html>
